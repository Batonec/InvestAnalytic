# Investor MCP server — environment template.
# Copy to .env and fill in. Do NOT commit real tokens (.env is git-ignored).

# ── Broker (Tinkoff Invest) ──────────────────────────────────────────────────
# API token. Empty → server runs on read-only MOCK data.
TINKOFF_INVEST_TOKEN=
# true/1 → use the Tinkoff SANDBOX instead of production (read-only either way).
TINKOFF_INVEST_SANDBOX=

# ── Storage & cache ──────────────────────────────────────────────────────────
# SQLite database (profile, selected accounts, snapshots, reports, recommendations, cache).
INVESTOR_MCP_STORAGE_PATH=./data/investor_mcp.db
# Composition cache TTL in seconds (positions/accounts/operations). Default: 1 day.
INVESTOR_MCP_CACHE_TTL_SECONDS=86400

# ── HTTP transport (streamable-http) ─────────────────────────────────────────
# Bind address. Keep 127.0.0.1 behind a reverse proxy / tunnel.
INVESTOR_MCP_HOST=127.0.0.1
INVESTOR_MCP_PORT=8000
# MCP endpoint path. For a no-auth deploy behind a tunnel use a SECRET path,
# e.g. /<random-hex>/mcp — then the URL itself is the access control.
INVESTOR_MCP_PATH=/mcp

# ── Security (optional) ──────────────────────────────────────────────────────
# If set, every request must send  Authorization: Bearer <token>
INVESTOR_MCP_AUTH_TOKEN=
# Comma-separated allowed Host header values (strict anti-DNS-rebinding mode).
# Empty → Host check disabled (fine behind a trusted proxy/tunnel).
INVESTOR_MCP_ALLOWED_HOSTS=
